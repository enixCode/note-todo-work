  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.23",
    "minio": "^8.0.7",
    "ts-fsrs": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
