{
  "name": "note-todo-work",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "API REST projects + notes brainstorm en Markdown, stockées dans MinIO, avec révision espacée FSRS.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
